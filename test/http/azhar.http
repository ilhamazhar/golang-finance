###############################################################################
# Azhar Finance - full e2e scenario (every endpoint)
#
# Run order matters: register/login first (captures {{access_token}} +
# {{refresh_token}} + {{user_id}}), then the rest.
#   - GoLand/IntelliJ: "Run all requests in file" (>> icon at top), or run
#     each request with the green gutter arrow, top to bottom.
#   - CI / headless:  ijhttp test/http/azhar.http --env local
#
# Vars come from http-client.env.json (+ http-client.private.env.json for the
# callback token). {{access_token}}, {{refresh_token}}, {{user_id}}, and
# {{order_ref}} are captured at runtime below.
###############################################################################


############################  1. AUTH  ########################################

### Register a fresh user
# Uses a unique email per run (epoch ms) so this scenario can re-run cleanly.
# @name register
POST {{base_url}}/auth/register
Content-Type: application/json

{
  "name": "{{test_name}}",
  "email": "test-{{$timestamp}}@azhar.test",
  "password": "{{test_password}}",
  "password_confirm": "{{test_password}}"
}

> {%
client.test("register 201", function () {
    client.assert(response.status === 201, "status " + response.status);
    client.assert(response.body.data.id, "no id in body");
    client.assert(response.body.data.email, "no email in body");
});
client.global.set("user_id", response.body.data.id);
client.global.set("registered_email", response.body.data.email);
%}

### Login -> capture access_token + refresh_token
# @name login
POST {{base_url}}/auth/login
Content-Type: application/json

{
  "email": "{{registered_email}}",
  "password": "{{test_password}}"
}

> {%
client.test("login 200 + tokens", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.access_token, "no access_token in body");
    client.assert(response.body.data.refresh_token, "no refresh_token in body");
});
client.global.set("access_token", response.body.data.access_token);
client.global.set("refresh_token", response.body.data.refresh_token);
%}

### Refresh access token -> rotates tokens
POST {{base_url}}/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}

> {%
client.test("refresh 200 + new tokens", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.access_token, "no access_token in body");
    client.assert(response.body.data.refresh_token, "no refresh_token in body");
});
client.global.set("access_token", response.body.data.access_token);
client.global.set("refresh_token", response.body.data.refresh_token);
%}


############################  2. ME  ##########################################

### Get current user profile
GET {{base_url}}/api/me/
Authorization: Bearer {{access_token}}

> {%
client.test("me 200", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.email, "no email in body");
});
%}

### Change password
PUT {{base_url}}/api/me/password
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "current_password": "{{test_password}}",
  "new_password": "{{test_password_new}}",
  "confirm_password": "{{test_password_new}}"
}

> {%
client.test("change password 200", function () {
    client.assert(response.status === 200, "status " + response.status);
});
%}

### Login again with NEW password -> rotate {{access_token}}/{{refresh_token}}
POST {{base_url}}/auth/login
Content-Type: application/json

{
  "email": "{{registered_email}}",
  "password": "{{test_password_new}}"
}

> {%
client.test("login with new password 200", function () {
    client.assert(response.status === 200, "status " + response.status);
});
client.global.set("access_token", response.body.data.access_token);
client.global.set("refresh_token", response.body.data.refresh_token);
%}


############################  3. PAYMENTS  ###################################

### Create QRIS -> capture order_ref   (needs Xendit test key)
# @name pay_qris
POST {{base_url}}/api/payments/qris
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "amount": 5000,
  "description": "E2E QRIS test"
}

> {%
client.test("qris created", function () {
    client.assert(response.status === 201, "status " + response.status + " (needs Xendit test key)");
    client.assert(response.body.data.order_ref, "no order_ref in body");
});
if (response.body.data && response.body.data.order_ref) {
    client.global.set("order_ref", response.body.data.order_ref);
}
%}

### Payment status BEFORE webhook -> expect PENDING
GET {{base_url}}/api/payments/{{order_ref}}
Authorization: Bearer {{access_token}}

> {%
client.test("status pending", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.status === "PENDING", "got " + response.body.data.status);
});
%}

### Webhook: payment.succeeded -> 200
POST {{base_url}}/webhooks/xendit
Content-Type: application/json
x-callback-token: {{callback_token}}

{
  "event": "payment.succeeded",
  "data": { "id": "pr-test-001", "reference_id": "{{order_ref}}", "status": "SUCCEEDED" }
}

> {%
client.test("succeeded webhook acked", function () {
    client.assert(response.status === 200, "status " + response.status);
});
%}

### Payment status AFTER succeeded -> expect PAID
GET {{base_url}}/api/payments/{{order_ref}}
Authorization: Bearer {{access_token}}

> {%
client.test("status paid", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.status === "PAID", "got " + response.body.data.status);
});
%}


############################  4. USERS  ######################################

### List users (paginated)
GET {{base_url}}/api/users?page=1&limit=10
Authorization: Bearer {{access_token}}

> {%
client.test("users list 200", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(Array.isArray(response.body.data), "data is not an array");
    client.assert(response.body.pagination, "no pagination block");
});
%}

### Get user by id (self)
GET {{base_url}}/api/users/{{user_id}}
Authorization: Bearer {{access_token}}

> {%
client.test("user by id 200", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.id === client.global.get("user_id"),
        "id mismatch: " + response.body.data.id);
});
%}

### Update user name
PUT {{base_url}}/api/users/{{user_id}}
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "name": "{{test_name_updated}}"
}

> {%
client.test("user updated 200", function () {
    client.assert(response.status === 200, "status " + response.status);
    client.assert(response.body.data.name === request.environment.get("test_name_updated"),
        "name not updated: " + response.body.data.name);
});
%}

### Delete user (self) - leaves a clean DB for re-runs
DELETE {{base_url}}/api/users/{{user_id}}
Authorization: Bearer {{access_token}}

> {%
client.test("user deleted 200", function () {
    client.assert(response.status === 200, "status " + response.status);
});
%}


############################  5. LOGOUT  #####################################

### Logout invalidates refresh token (already-deleted user — token still in redis)
# Use a fresh login first? No — current refresh_token is still valid until
# revoked. Logout should still succeed (token revocation is independent of the
# user row). Some setups will 401 here if the cascade nuked sessions; allow it.
POST {{base_url}}/auth/logout
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}

> {%
client.test("logout handled", function () {
    client.assert([200, 401].includes(response.status), "status " + response.status);
});
%}


############################  6. NEGATIVE & AUTH  ############################

### No token -> 401 on protected route
GET {{base_url}}/api/me/

> {%
client.test("no token 401", function () {
    client.assert(response.status === 401, "status " + response.status);
});
%}

### Wrong password -> 401
POST {{base_url}}/auth/login
Content-Type: application/json

{ "email": "{{registered_email}}", "password": "definitely-wrong" }

> {%
client.test("wrong password 401", function () {
    client.assert(response.status === 401, "status " + response.status);
});
%}

### Register with mismatched confirm -> 422 (validation)
POST {{base_url}}/auth/register
Content-Type: application/json

{
  "name": "Bad Confirm",
  "email": "bad-confirm-{{$timestamp}}@azhar.test",
  "password": "secret123",
  "password_confirm": "DIFFERENT"
}

> {%
client.test("password mismatch 422", function () {
    client.assert(response.status === 422, "status " + response.status);
});
%}

### Register missing required fields -> 422 (validation)
POST {{base_url}}/auth/register
Content-Type: application/json

{ "email": "missing-fields@azhar.test" }

> {%
client.test("missing fields 422", function () {
    client.assert(response.status === 422, "status " + response.status);
});
%}

### Invalid UUID on user GET -> 400
GET {{base_url}}/api/users/not-a-uuid
Authorization: Bearer {{access_token}}

> {%
client.test("bad uuid 400", function () {
    client.assert(response.status === 400, "status " + response.status);
});
%}

### Bad callback token -> webhook still returns 200 (auth failure is logged, not surfaced)
# NOTE: Azhar Finance's webhook handler swallows the verify error and always
# returns 200 (Xendit best-practice: never retry by signaling failure). If you
# expect 401 here, change the handler to return c.Status(http.StatusUnauthorized)
# on s.xendit.VerifyCallbackToken failure.
POST {{base_url}}/webhooks/xendit
Content-Type: application/json
x-callback-token: wrong-token

{ "event": "payment.succeeded", "data": { "id": "x", "reference_id": "ORDER-NONE", "status": "SUCCEEDED" } }

> {%
client.test("bad callback token still 200", function () {
    client.assert(response.status === 200, "status " + response.status);
});
%}

### Unknown order_ref -> 404
GET {{base_url}}/api/payments/ORDER-DOES-NOT-EXIST
Authorization: Bearer {{access_token}}

> {%
client.test("unknown order_ref 404", function () {
    client.assert(response.status === 404, "status " + response.status);
});
%}
