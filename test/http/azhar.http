############################  6. LOGOUT  #####################################

### Logout invalidates refresh token (already-deleted user — token still in redis)
# Use a fresh login first? No — current refresh_token is still valid until
# revoked. Logout should still succeed (token revocation is independent of the
# user row). Some setups will 401 here if the cascade nuked sessions; allow it.
POST {{base_url}}/auth/logout
Content-Type: application/json

{
  "refresh_token": "{{refresh_token}}"
}

> {%
client.test("logout handled", function () {
    client.assert([200, 401].includes(response.status), "status " + response.status);
});
%}


