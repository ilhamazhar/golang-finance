# Server
SERVER_PORT=
APP_ENV=
APP_BASE_URL=

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY_HOURS=
JWT_REFRESH_EXPIRY_HOURS=

# Email verification
EMAIL_VERIFY_EXPIRY_HOURS=

# SMTP (leave SMTP_HOST empty to log emails to the console instead of sending)
# Gmail: host=smtp.gmail.com port=587, username=your@gmail.com,
#        password=<App Password> (requires 2FA; not your normal password)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Xendit
XENDIT_API_KEY=
XENDIT_CALLBACK_TOKEN=

# CORS (comma-separated origins, use * to allow all)
CORS_ALLOWED_ORIGINS=

# Rate limiting (count per period; period: second | minute | hour | day)
RATE_LIMIT_AUTH_MAX=
RATE_LIMIT_AUTH_PERIOD=
RATE_LIMIT_API_MAX=
RATE_LIMIT_API_PERIOD=
